{
  "name": "novelfork-studio",
  "version": "0.1.0",
  "language": "zh",
  "llm": {
    "provider": "openai",
    "baseUrl": "",
    "model": "gpt-4o"
  },
  "notify": [],
  "daemon": {
    "schedule": {
      "radarCron": "0 */6 * * *",
      "writeCron": "*/15 * * * *"
    },
    "maxConcurrentBooks": 3
  },
  "mcpServers": [
    {
      "name": "example-filesystem",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"],
      "enabled": false
    },
    {
      "name": "example-brave-search",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "your-api-key-here"
      },
      "enabled": false
    }
  ]
}
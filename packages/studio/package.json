{
  "name": "@vivy1024/novelfork-studio",
  "version": "0.8.5",
  "description": "NovelFork Studio — Web workbench for Chinese web novel writing",
  "type": "module",
  "main": "dist/api/index.js",
  "types": "dist/api/index.d.ts",
  "exports": {
    ".": "./dist/api/index.js",
    "./api/lib/ai-request-observer": "./src/api/lib/ai-request-observer.ts",
    "./api/lib/token-counter": "./src/api/lib/token-counter.ts",
    "./api/lib/user-config-service": "./src/api/lib/user-config-service.ts",
    "./api/lib/rhythm-analyzer": "./src/api/lib/rhythm-analyzer.ts",
    "./api/lib/ai-gate": "./src/api/lib/ai-gate.ts",
    "./api/lib/provider-runtime-store": "./src/api/lib/provider-runtime-store.ts",
    "./api/lib/runtime-model-pool": "./src/api/lib/runtime-model-pool.ts",
    "./api/lib/llm-runtime-service": "./src/api/lib/llm-runtime-service.ts",
    "./api/errors": "./src/api/errors.ts",
    "./api/safety": "./src/api/safety.ts",
    "./api/routes/context": "./src/api/routes/context.ts",
    "./shared/author-materials": "./src/shared/author-materials.ts",
    "./shared/agent-native-workspace": "./src/shared/agent-native-workspace.ts",
    "./shared/session-types": "./src/shared/session-types.ts",
    "./api/lib/resource-checkpoint-service": "./src/api/lib/resource-checkpoint-service.ts"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vivy1024/novelfork.git",
    "directory": "packages/studio"
  },
  "scripts": {
    "prepack": "npm run build && node ../../scripts/prepare-package-for-publish.mjs",
    "postpack": "node ../../scripts/restore-package-json.mjs",
    "prepublishOnly": "node ../../scripts/verify-no-workspace-protocol.mjs .",
    "dev": "vite --host --port 4567",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "pnpm --dir ../core build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "test": "vitest run",
    "compile": "bun scripts/compile.ts",
    "typecheck": "pnpm --dir ../core build && tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource-variable/geist": "5.2.8",
    "@hono/node-server": "1.13.0",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-router": "1.169.2",
    "@tiptap/core": "2.27.2",
    "@tiptap/extension-placeholder": "3.23.4",
    "@tiptap/pm": "2.27.2",
    "@tiptap/react": "2.27.2",
    "@tiptap/starter-kit": "2.27.2",
    "@types/react-grid-layout": "2.1.0",
    "@vivy1024/novelfork-core": "workspace:*",
    "@vivy1024/novelfork-novel-plugin": "workspace:*",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "@xyflow/react": "12.10.2",
    "broad-infinite-list": "1.4.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "diff": "9.0.0",
    "dotenv": "16.4.0",
    "flowtoken": "1.0.40",
    "hono": "4.7.0",
    "katex": "^0.16.45",
    "lucide-react": "0.577.0",
    "novel": "1.0.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-grid-layout": "2.2.3",
    "react-markdown": "10.1.0",
    "react-resizable": "3.1.3",
    "react-syntax-highlighter": "16.1.1",
    "recharts": "3.8.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "4.0.8",
    "shiki": "4.0.2",
    "sonner": "^1.7.4",
    "tailwind-merge": "3.5.0",
    "tiptap-markdown": "0.8.10",
    "tw-animate-css": "1.4.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "4.4.0",
    "autoprefixer": "10.4.0",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "4.20.6",
    "typescript": "^5.7.0",
    "vite": "6.0.0",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "3.0.0",
    "workbox-window": "7.4.0",
    "ws": "8.20.0"
  }
}

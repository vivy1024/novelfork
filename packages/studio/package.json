{
  "name": "@vivy1024/novelfork-studio",
  "version": "0.0.2",
  "description": "NovelFork Studio — Web workbench for Chinese web novel writing",
  "type": "module",
  "main": "dist/api/index.js",
  "types": "dist/api/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vivy1024/novelfork.git",
    "directory": "packages/studio"
  },
  "scripts": {
    "prepack": "npm run build && node ../../scripts/prepare-package-for-publish.mjs",
    "postpack": "node ../../scripts/restore-package-json.mjs",
    "prepublishOnly": "node ../../scripts/verify-no-workspace-protocol.mjs .",
    "dev": "vite --host --port 4567",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "pnpm --dir ../core build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "test": "vitest run",
    "compile": "bun scripts/compile.ts",
    "typecheck": "pnpm --dir ../core build && tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource-variable/geist": "5.2.8",
    "@hono/node-server": "1.13.0",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@tiptap/core": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "@types/react-grid-layout": "2.1.0",
    "@vivy1024/novelfork-core": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "dotenv": "16.4.0",
    "hono": "4.7.0",
    "katex": "^0.16.45",
    "lucide-react": "0.577.0",
    "novel": "1.0.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-grid-layout": "2.2.3",
    "react-markdown": "10.1.0",
    "react-resizable": "3.1.3",
    "react-syntax-highlighter": "16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "4.0.8",
    "sonner": "^1.7.4",
    "tailwind-merge": "3.5.0",
    "tiptap-markdown": "0.8.10",
    "tw-animate-css": "1.4.0",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "22.0.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/react-syntax-highlighter": "15.5.13",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "4.4.0",
    "autoprefixer": "10.4.0",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.19",
    "tsx": "4.20.6",
    "typescript": "^5.7.0",
    "vite": "6.0.0",
    "vite-plugin-pwa": "1.2.0",
    "vitest": "3.0.0",
    "workbox-window": "7.4.0",
    "ws": "8.20.0"
  }
}

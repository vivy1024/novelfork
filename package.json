{
  "name": "novelfork",
  "version": "0.0.1",
  "private": true,
  "description": "NovelFork — Forked from InkOS, specialized AI-assisted workbench for Chinese web novel creation",
  "keywords": [
    "ai-novel-writing",
    "web-novel",
    "chinese-novel",
    "novel-generator",
    "autonomous-writing",
    "xuanhuan",
    "xianxia",
    "multi-agent",
    "creative-writing-ai",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivy1024/novelfork"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "verify:publish-manifests": "node scripts/verify-no-workspace-protocol.mjs packages/core packages/cli packages/studio",
    "release": "pnpm build && pnpm test",
    "version": "pnpm -r exec npm version"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "@tiptap/core": "2.27.2",
    "@tiptap/extension-text-style": "3.22.3",
    "@tiptap/pm": "2.27.2",
    "@tiptap/react": "3.22.3",
    "@tiptap/starter-kit": "3.22.3",
    "glob": "13.0.6",
    "idb": "8.0.3",
    "novel": "1.0.2",
    "tiktoken": "1.0.22"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "esbuild": "0.28.0"
  }
}
